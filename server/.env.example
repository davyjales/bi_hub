# Copie para .env e preencha os valores.

JWT_SECRET=altere-esta-chave-secreta
DB_NAME=bi_hub
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=

# Recuperação de palavra-passe (SMTP) — obrigatório para "Esqueci a palavra-passe"
# Sem SMTP_HOST e SMTP_FROM a funcionalidade fica desactivada.
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@empresa.com
SMTP_PASS=sua-senha-ou-app-password
SMTP_FROM="Visteon BI Hub" <noreply@empresa.com>
# URL da página de login (opcional, link no e-mail)
APP_LOGIN_URL=http://localhost:3000/auth.html
MAIL_APP_NAME=Visteon BI Hub

# Seed (opcional)
# SEED_ADMIN_EMAIL=admin@empresa.com
